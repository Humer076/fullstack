{
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": ["./*"]
    },
    "allowJs": true,
    "checkJs": false,
    "jsx": "preserve",
    "moduleResolution": "node",
    "target": "ESNext"
  },
  "include": [
    "next.config.js",
    "app/**/*",
    "components/**/*",
    "lib/**/*",
    "pages/**/*",
    "src/**/*"
  ],
  "exclude": ["node_modules", ".next", "out", "dist"]
}
